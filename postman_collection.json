              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "3.2 Create User (cajero)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(json.id).to.be.a('string'));",
                  "if(json.id) pm.collectionVariables.set('newUserId', json.id);"
