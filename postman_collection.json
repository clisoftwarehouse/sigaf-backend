                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cajero1\",\n  \"password\": \"cajero123\",\n  \"fullName\": \"Juan Cajero\",\n  \"cedula\": \"V-12345678\",\n  \"email\": \"cajero1@sigaf.com\",\n  \"phone\": \"+58412111111\",\n  \"role\": { \"id\": \"{{roleIdCajero}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "3.3 Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Username matches', () => pm.expect(json.username).to.equal('cajero1'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{newUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{newUserId}}"]
            }
          }
        },
        {
          "name": "3.4 Update User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Name updated', () => pm.expect(json.fullName).to.equal('Juan Cajero Actualizado'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Juan Cajero Actualizado\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/users/{{newUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{newUserId}}"]
            }
          }
        },
        {
          "name": "3.5 Delete User (Soft)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{newUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{newUserId}}"]
            }
          }
        }
      ]
