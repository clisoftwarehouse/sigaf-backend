{
  "info": {
    "name": "SIGAF Backend - Flujo Completo",
    "description": "Ejecutar en orden: Login → Roles → Users → Config → Catálogos → Productos → Inventario",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "adminUserId", "value": "" },
    { "key": "newUserId", "value": "" },
    { "key": "roleIdAdmin", "value": "" },
    { "key": "roleIdCajero", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "brandId", "value": "" },
    { "key": "activeIngredientId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "branchId", "value": "" },
    { "key": "terminalId", "value": "" },
    { "key": "locationId", "value": "" },
    { "key": "lotId", "value": "" }
  ],
  "item": [
    {
      "name": "01. AUTH - Login y Sesión",
      "item": [
        {
          "name": "1.1 Login (admin/admin123)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
                  "if(json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "if(json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "if(json.user && json.user.id) pm.collectionVariables.set('adminUserId', json.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin\",\n  \"password\": \"admin123\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/email/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "email", "login"]
            }
          }
        },
        {
          "name": "1.2 Me (Ver perfil)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has username', () => pm.expect(json.username).to.equal('admin'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "1.3 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "if(json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "if(json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{refreshToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        }
      ]
    },
    {
      "name": "02. ROLES - Listar roles",
      "item": [
        {
          "name": "2.1 Get All Roles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has roles', () => pm.expect(json).to.be.an('array'));",
                  "json.forEach(role => {",
                  "  if(role.name === 'administrador') pm.collectionVariables.set('roleIdAdmin', role.id);",
                  "  if(role.name === 'cajero') pm.collectionVariables.set('roleIdCajero', role.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] }
          }
        }
      ]
    },
